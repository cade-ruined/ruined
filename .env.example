# ─── Shopify Storefront (headless commerce) ──────────────────────────────────
# Copy to `.env.local` and fill in. With these UNSET, the store renders the
# local fallback catalogue (src/data/products.ts) and the CTA shows "Enquire".

# Your store's myshopify domain (no protocol), e.g. ruined-studio.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Public Storefront API access token.
# Shopify admin → Settings → Apps and sales channels → Develop apps →
# create an app → Storefront API → install → copy the Storefront access token.
# Grant: unauthenticated_read_product_listings, unauthenticated_write_checkouts.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional — Storefront API version (defaults to 2024-10 in src/lib/shopify.ts).
SHOPIFY_API_VERSION=2026-07

# Shared secret for on-demand ISR. Used by /api/revalidate; configure the same
# value as a query param on your Shopify products webhook.
# Shopify app client secret used to verify X-Shopify-Hmac-Sha256 webhook
# signatures. Do not use the public Storefront token here.
SHOPIFY_WEBHOOK_SECRET=

# Optional endpoint for sendBeacon Web Vitals payloads.
NEXT_PUBLIC_ANALYTICS_ENDPOINT=

# Canonical production origin, e.g. https://ruined.studio
NEXT_PUBLIC_SITE_URL=https://ruined.studio

# Public destination used by fallback product enquiry links.
NEXT_PUBLIC_CONTACT_EMAIL=studio@ruined.studio
